# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # server-only, never expose

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_TOURNAMENT_YEAR=2026

# ─── Models ─────────────────────────────────────────────────
# Statchance uses a Poisson goal-expectancy model parameterized by SPI-style
# ratings. PICKCHANCE_BIAS shifts toward contrarian picks (0 = pure win prob,
# 1 = maximum contrarian). Default 0.35 for pools of ~50 people.
STATCHANCE_SIMULATIONS=10000
PICKCHANCE_BIAS=0.35

# ─── OAuth (optional) ───────────────────────────────────────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
